# Frontend-specific environment variables
## DO NOT EDIT THIS FILE MANUALLY
# VITE_SESSION_TIMEOUT_MINUTES is auto-synced from root .env by sync-env.js
# Edit SESSION_TIMEOUT_MINUTES in the root .env and run `node sync-env.js` to update this value.
#
# (Set VITE_SESSION_TIMEOUT_MINUTES here ONLY if not using sync script)
VITE_SESSION_TIMEOUT_MINUTES=5
